{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ferret",
  "scopeName": "source.ferret",
  "fileTypes": ["fl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#modules" },
    { "include": "#operators" },
    { "include": "#match" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(return|use|match|type|external|fn)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            },
            {
              "name": "variable.other.placeholder",
              "match": "\\{[^}]*\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function",
          "match": "(?<=fn\\s)\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "entity.name.function",
          "match": "(?<=^|\\s)([a-zA-Z_][a-zA-Z0-9_]*)\\s+(?=[a-zA-Z_][a-zA-Z0-9_]*\\s*\\()"
        },
        {
          "name": "entity.name.function",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\."
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type",
          "match": "(?<=type\\s)\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "entity.name.type",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "storage.type",
          "match": "\\b(int|string|bool|float|char)\\b"
        },
        {
          "name": "storage.type",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "support.module",
          "match": "(?<=use\\s)\\b[a-z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "support.module",
          "match": "(?<=use\\s)[a-z][a-zA-Z0-9_]*\\s*:\\s*\\{[^}]*\\}"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator",
          "match": "\\|>|\\+|-|\\*|/|%|==|!=|<=|>=|<|>|&&|\\|\\||!"
        },
        {
          "name": "punctuation.separator",
          "match": "[,;]"
        },
        {
          "name": "punctuation.definition",
          "match": "[\\{\\}\\[\\]\\(\\)]"
        }
      ]
    },
    "match": {
      "patterns": [
        {
          "name": "keyword.control.match",
          "match": "\\bmatch\\b"
        },
        {
          "name": "constant.language",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
