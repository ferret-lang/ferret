{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ferret",
  "scopeName": "source.ferret",
  "fileTypes": ["fl"],
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "name": "storage.type.ferret",
      "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\b"
    },
    {
      "name": "entity.name.function.ferret",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },
    {
      "name": "support.module.ferret",
      "match": "(?<=use\\s)\\b[a-z][a-zA-Z0-9_]*\\b"
    },
    {
      "name": "keyword.operator.pipe.ferret",
      "match": "\\|>"
    },
    {
      "name": "comment.line.number-sign.ferret",
      "match": "#.*$"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ferret",
          "match": "\\b(fn|type|use|return|match)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ferret",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ferret",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
