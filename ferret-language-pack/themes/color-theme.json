{
  "name": "Ferret Theme",
  "type": "dark",
  "colors": {
    "editor.foreground": "#dcdcdc",
    "editor.background": "#1e1e1e",
    "editorCursor.foreground": "#ffffff",
    "editor.lineHighlightBackground": "#2b2b2b",
    "editorLineNumber.foreground": "#5a5a5a",
    "editor.selectionBackground": "#264f78",
    "editor.inactiveSelectionBackground": "#3a3d41"
  },
  "tokenColors": [
    {
      "scope": "keyword.control.ferret",
      "settings": {
        "foreground": "#ff79c6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage.type.ferret",
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": "entity.name.function.ferret",
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": "support.module.ferret",
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": "keyword.operator.pipe.ferret",
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "scope": "comment.line.number-sign.ferret",
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string.quoted.double.ferret",
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": "constant.character.escape.ferret",
      "settings": {
        "foreground": "#ff5555"
      }
    }
  ]
}
